---
import type { RoomId, SupportedLang } from '../types';

interface Props {
  roomId: RoomId;
  lang?: SupportedLang;
}

const { roomId, lang = 'fr' } = Astro.props;

const translations = {
  fr: {
    loading: 'Chargement des disponibilités...',
    prev: 'Mois précédent',
    next: 'Mois suivant',
    selected: 'Dates sélectionnées :',
    checkIn: 'Arrivée',
    checkOut: 'Départ',
    selectInstruction: 'Sélectionnez vos dates d’arrivée et de départ',
  },
  en: {
    loading: 'Loading availability...',
    prev: 'Previous month',
    next: 'Next month',
    selected: 'Selected dates:',
    checkIn: 'Check-in',
    checkOut: 'Check-out',
    selectInstruction: 'Select your check-in and check-out dates',
  }
};

const t = translations[lang];
---

<div
  class="calendar-widget bg-white p-6 rounded-2xl shadow-xl border border-stone-200 max-w-4xl mx-auto"
  data-room-id={roomId}
  data-lang={lang}
>
  <!-- Header & Navigation -->
  <div class="flex items-center justify-between mb-6 pb-4 border-b border-stone-100">
    <button
      id="prev-month-btn"
      class="p-2 hover:bg-stone-100 rounded-full transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
      aria-label={t.prev}
    >
      <svg class="w-5 h-5 text-stone-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <div class="text-sm font-medium text-stone-600" id="calendar-status">
      <span class="inline-block animate-pulse">{t.loading}</span>
    </div>

    <button
      id="next-month-btn"
      class="p-2 hover:bg-stone-100 rounded-full transition-colors"
      aria-label={t.next}
    >
      <svg class="w-5 h-5 text-stone-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>

  <!-- Conteneur des Mois Grid (1 col mobile, 2 cols desktop) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="months-container">
    <!-- Le rendu dynamique des mois est injecté ici par JS -->
  </div>

  <!-- Légende & Résumé -->
  <div class="mt-8 pt-4 border-t border-stone-100 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-stone-500">
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-white border border-stone-300"></span>
        <span>Disponible</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-stone-200"></span>
        <span>Occupé</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-amber-700"></span>
        <span>Sélectionné</span>
      </div>
    </div>

    <div id="selected-dates-summary" class="font-medium text-stone-800 text-sm">
      {t.selectInstruction}
    </div>
  </div>
</div>

<script>
  // Logique Client-Side
  class CalendarWidget {
    container: HTMLElement;
    roomId: string;
    lang: 'fr' | 'en';
    currentDate: Date;
    bookedDates: Set<string> = new Set();
    checkInDate: string | null = null;
    checkOutDate: string | null = null;

    constructor(container: HTMLElement) {
      this.container = container;
      this.roomId = container.dataset.roomId || '';
      this.lang = (container.dataset.lang as 'fr' | 'en') || 'fr';
      this.currentDate = new Date();
      this.currentDate.setDate(1); // Début au 1er du mois en cours

      this.init();
    }

    async init() {
      this.bindEvents();
      await this.fetchBookedDates();
      this.render();
    }

    bindEvents() {
      const prevBtn = this.container.querySelector('#prev-month-btn');
      const nextBtn = this.container.querySelector('#next-month-btn');

      prevBtn?.addEventListener('click', () => {
        this.currentDate.setMonth(this.currentDate.getMonth() - 1);
        this.render();
      });

      nextBtn?.addEventListener('click', () => {
        this.currentDate.setMonth(this.currentDate.getMonth() + 1);
        this.render();
      });
    }

    async fetchBookedDates() {
      try {
        const res = await fetch(`/api/calendar/${this.roomId}`);
        if (res.ok) {
          const data = await res.json();
          this.bookedDates = new Set(data.bookedDates);
          const statusEl = this.container.querySelector('#calendar-status');
          if (statusEl) statusEl.innerHTML = '';
        }
      } catch (err) {
        console.error('Erreur chargement calendrier:', err);
      }
    }

    render() {
      const monthsContainer = this.container.querySelector('#months-container');
      if (!monthsContainer) return;

      monthsContainer.innerHTML = '';

      // Mois 1
      const month1 = new Date(this.currentDate);
      // Mois 2
      const month2 = new Date(this.currentDate);
      month2.setMonth(month2.getMonth() + 1);

      monthsContainer.appendChild(this.createMonthHTML(month1));
      monthsContainer.appendChild(this.createMonthHTML(month2));

      this.updatePrevButtonState();
      this.attachDayClickListeners();
      this.updateSummary();
    }

    updatePrevButtonState() {
      const prevBtn = this.container.querySelector('#prev-month-btn') as HTMLButtonElement;
      const today = new Date();
      const isCurrentMonth =
        this.currentDate.getFullYear() === today.getFullYear() &&
        this.currentDate.getMonth() === today.getMonth();

      if (prevBtn) {
        prevBtn.disabled = isCurrentMonth;
      }
    }

    createMonthHTML(date: Date): HTMLElement {
      const monthDiv = document.createElement('div');
      monthDiv.className = 'month-block';

      const monthName = date.toLocaleDateString(this.lang === 'fr' ? 'fr-FR' : 'en-US', {
        month: 'long',
        year: 'numeric',
      });

      const year = date.getFullYear();
      const month = date.getMonth();

      // Jours du mois
      const firstDayIndex = (new Date(year, month, 1).getDay() + 6) % 7; // Lundi = 0
      const daysInMonth = new Date(year, month + 1, 0).getDate();

      const daysOfWeek = this.lang === 'fr'
        ? ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim']
        : ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

      let html = `
        <h3 class="text-base font-semibold text-stone-900 capitalize text-center mb-4">${monthName}</h3>
        <div class="grid grid-cols-7 gap-1 text-center text-xs font-medium text-stone-400 mb-2">
          ${daysOfWeek.map(d => `<div>${d}</div>`).join('')}
        </div>
        <div class="grid grid-cols-7 gap-1 text-center">
      `;

      // Cases vides
      for (let i = 0; i < firstDayIndex; i++) {
        html += `<div class="h-9"></div>`;
      }

      const todayStr = new Date().toISOString().split('T')[0];

      // Jours du mois
      for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;

        const isBooked = this.bookedDates.has(dateStr);
        const isPast = dateStr < todayStr;
        const isDisabled = isBooked || isPast;

        const isCheckIn = dateStr === this.checkInDate;
        const isCheckOut = dateStr === this.checkOutDate;
        const isInRange = this.checkInDate && this.checkOutDate &&
                          dateStr > this.checkInDate && dateStr < this.checkOutDate;

        let dayClass = "h-9 w-9 mx-auto flex items-center justify-center text-sm rounded-full transition-all cursor-pointer font-medium ";

        if (isDisabled) {
          dayClass += "bg-stone-100 text-stone-300 line-through cursor-not-allowed";
        } else if (isCheckIn || isCheckOut) {
          dayClass += "bg-amber-700 text-white shadow-md font-bold scale-105";
        } else if (isInRange) {
          dayClass += "bg-amber-100 text-amber-900 rounded-none";
        } else {
          dayClass += "text-stone-700 hover:bg-amber-100 hover:text-amber-800";
        }

        html += `
          <button
            type="button"
            class="day-btn p-0.5"
            data-date="${dateStr}"
            ${isDisabled ? 'disabled' : ''}
          >
            <div class="${dayClass}">${day}</div>
          </button>
        `;
      }

      html += `</div>`;
      monthDiv.innerHTML = html;
      return monthDiv;
    }

    attachDayClickListeners() {
      const dayBtns = this.container.querySelectorAll('.day-btn:not([disabled])');
      dayBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const dateStr = (e.currentTarget as HTMLElement).dataset.date;
          if (!dateStr) return;

          this.handleDateSelect(dateStr);
        });
      });
    }

    handleDateSelect(dateStr: string) {
      if (!this.checkInDate || (this.checkInDate && this.checkOutDate)) {
        // Premier clic : sélection du check-in
        this.checkInDate = dateStr;
        this.checkOutDate = null;
      } else if (this.checkInDate && !this.checkOutDate) {
        // Second clic : sélection du check-out
        if (dateStr < this.checkInDate) {
          this.checkInDate = dateStr;
        } else {
          // Vérifier qu'il n'y a pas de jour réservé au milieu de la plage
          if (this.hasBookedDaysInRange(this.checkInDate, dateStr)) {
            this.checkInDate = dateStr;
          } else {
            this.checkOutDate = dateStr;
          }
        }
      }

      this.render();

      // Émission d'un événement personnalisé pour le composant parent
      const event = new CustomEvent('datesSelected', {
        detail: {
          roomId: this.roomId,
          checkIn: this.checkInDate,
          checkOut: this.checkOutDate,
        },
        bubbles: true,
      });
      this.container.dispatchEvent(event);
    }

    hasBookedDaysInRange(start: string, end: string): boolean {
      let current = new Date(start);
      const endDate = new Date(end);

      while (current < endDate) {
        const dateStr = current.toISOString().split('T')[0];
        if (this.bookedDates.has(dateStr)) return true;
        current.setDate(current.getDate() + 1);
      }
      return false;
    }

    updateSummary() {
      const summaryEl = this.container.querySelector('#selected-dates-summary');
      if (!summaryEl) return;

      if (this.checkInDate && this.checkOutDate) {
        summaryEl.innerHTML = `
          <span class="text-amber-800 font-semibold">${this.checkInDate}</span>
          →
          <span class="text-amber-800 font-semibold">${this.checkOutDate}</span>
        `;
      } else if (this.checkInDate) {
        summaryEl.innerHTML = `Arrivée : <span class="text-amber-800 font-semibold">${this.checkInDate}</span> (Choisissez la date de départ)`;
      } else {
        summaryEl.innerHTML = this.lang === 'fr'
          ? 'Sélectionnez vos dates d’arrivée et de départ'
          : 'Select your check-in and check-out dates';
      }
    }
  }

  // Initialisation sur la page
  document.addEventListener('DOMContentLoaded', () => {
    const widgets = document.querySelectorAll('.calendar-widget');
    widgets.forEach(w => new CalendarWidget(w as HTMLElement));
  });
</script>
